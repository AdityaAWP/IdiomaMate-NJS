        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(broker_hop2_transit_ms_bucket[1m])) by (le, broker))",
          "legendFormat": "p95 {{broker}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(broker_hop2_transit_ms_bucket[1m])) by (le, broker))",
          "legendFormat": "p99 {{broker}}",
          "refId": "C"
