        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".*matching.*\"}[1m]) * 100",
          "legendFormat": "matching CPU",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".*notification.*\"}[1m]) * 100",
